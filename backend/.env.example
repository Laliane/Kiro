# LLM Provider configuration
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here

# Embedding model (e.g. text-embedding-3-small for OpenAI)
EMBEDDING_MODEL=text-embedding-3-small

# JWT secret for token signing
JWT_SECRET=change_me_to_a_strong_random_secret

# External API integration
EXTERNAL_API_URL=https://your-external-api.example.com/endpoint
EXTERNAL_API_AUTH_TYPE=bearer
EXTERNAL_API_CREDENTIALS=your_credentials_here
