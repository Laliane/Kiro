# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=your_chat_deployment_name
AZURE_OPENAI_EMBEDDING_MODEL=your_embedding_deployment_name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# LLM Provider Configuration
LLM_PROVIDER=azure
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB Configuration
CHROMA_PATH=./chroma_data

# Default Knowledge Base CSV Path
# Define o caminho para o arquivo CSV que será carregado automaticamente ao iniciar a aplicação
# Se não estiver definido ou o arquivo não existir, a base de conhecimento ficará vazia até upload manual
DEFAULT_KB_CSV_PATH=./data/knowledge_base.csv

# External API Configuration (optional)
EXTERNAL_API_URL=https://api.example.com/endpoint
EXTERNAL_API_KEY=your_external_api_key_here

# JWT Configuration
JWT_SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
